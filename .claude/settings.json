{
  "permissions": {
    "allow": [
      "Bash(mkdir -p *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(jq *)",
      "Bash(npx serve *)",
      "Bash(python3 -m http.server *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "enableAllProjectMcpServers": true
}
